// Gaussian Splatting — first-class Lux declaration
// Generates preprocess compute + render vertex + render fragment shaders

splat GaussianCloud {
    sh_degree: 0,
    kernel: ellipse,
    color_space: srgb,
    sort: camera_distance,
    alpha_cutoff: 0.004,
}

pipeline SplatViewer {
    mode: gaussian_splat,
    splat: GaussianCloud,
}
