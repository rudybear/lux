// Gaussian Splatting with SH degree 3 — full view-dependent color
// Generates preprocess compute + render vertex + render fragment shaders

splat GaussianCloud {
    sh_degree: 3,
    kernel: ellipse,
    color_space: linear,
    sort: camera_distance,
    alpha_cutoff: 0.004,
}

pipeline SplatViewer {
    mode: gaussian_splat,
    splat: GaussianCloud,
}
